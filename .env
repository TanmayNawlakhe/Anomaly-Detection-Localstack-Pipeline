TRAINING_DATA_PATH="synthetic_service_metrics.csv"
MODEL_DIR="models"
# TEST MODE: window=12, 5-minute buckets → need only ~1 hour of data to test
# PRODUCTION: TRAINING_WINDOW=24, TRAINING_AGGREGATION_INTERVAL='h'
TRAINING_WINDOW=12
TRAINING_AGGREGATION_INTERVAL='5min'

INGESTION_ENDPOINT="@@/030.23/metrics"
INGESTION_DATA_PATH="synthetic_service_metrics.csv"
INGESTION_AGGREGATION_INTERVAL='5min'

COMPOSITE_SIGNAL_ALPHA=200
COMPOSITE_SIGNAL_BETA=2

MONGO_URI="mongodb://localhost:27017/"
MONGO_DB_NAME="AggMetrics"
MONGO_COLLECTION_NAME="AggData"

DETECTION_WINDOW=2

OUTPUT_DIR="output"